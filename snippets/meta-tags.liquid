<meta charset="utf-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<meta name="viewport" content="width=device-width,initial-scale=1">
<meta name="view-transition" content="same-origin">
<meta name="theme-color" content="#1A2744">

{%- liquid
  assign store_name = shop.name | default: "DIESMAX"
  assign store_location = "Zacatecas"
  assign store_tagline = "Refacciones Diésel y Servicio Pesado"

  # ── Title tag por tipo de página ──────────────────────────
  if request.page_type == 'product'
    if product.variants.first.sku != blank
      assign seo_title = product.title | append: ' — No. ' | append: product.variants.first.sku | append: ' | ' | append: store_name
    else
      assign seo_title = product.title | append: ' | Refacción Diésel | ' | append: store_name
    endif
  elsif request.page_type == 'collection'
    assign seo_title = collection.title | append: ' Diésel | ' | append: store_name | append: ' ' | append: store_location
  elsif request.page_type == 'index'
    assign seo_title = store_name | append: ' — ' | append: store_tagline | append: ' | ' | append: store_location
  elsif request.page_type == 'search'
    assign seo_title = 'Buscar Refacciones Diésel | ' | append: store_name
  else
    assign seo_title = page_title | default: store_name
    unless seo_title contains store_name
      assign seo_title = seo_title | append: ' | ' | append: store_name
    endunless
  endif

  # ── Meta description con fallback keyword-rich ────────────
  assign meta_desc = page_description
  if meta_desc == blank
    if request.page_type == 'product'
      assign meta_desc = product.title
      if product.variants.first.sku != blank
        assign meta_desc = meta_desc | append: ' · No. Parte: ' | append: product.variants.first.sku
      endif
      if product.vendor != blank
        assign meta_desc = meta_desc | append: ' — Marca: ' | append: product.vendor
      endif
      assign meta_desc = meta_desc | append: '. Refacción diésel original disponible en DIESMAX. Envíos desde Zacatecas a toda la República. Cotiza por WhatsApp.'
    elsif request.page_type == 'collection'
      assign meta_desc = collection.title | append: ' — Refacciones para tractocamiones diésel Kenworth, International y Freightliner. Cummins, Fleetguard, Gonher y más. Disponibles en DIESMAX Zacatecas. Envíos a toda la República.'
    elsif request.page_type == 'index'
      assign meta_desc = 'DIESMAX — Refaccionaria digital especializada en refacciones diésel y servicio pesado. Filtros Fleetguard, frenos de aire, lubricantes Bardahl y más para tractocamiones. Envíos desde Zacatecas a toda la República.'
    elsif request.page_type == 'search'
      assign meta_desc = 'Busca refacciones diésel por número de parte, marca o aplicación en DIESMAX. Kenworth, International, Freightliner, Cummins ISX, L10. Cotiza por WhatsApp desde Zacatecas.'
    else
      assign meta_desc = shop.description | default: 'DIESMAX — Refacciones diésel y servicio pesado para tractocamiones. Envíos desde Zacatecas a toda la República Mexicana.'
    endif
  endif

  # ── OG ───────────────────────────────────────────────────
  assign og_title = seo_title
  assign og_url = canonical_url | default: request.origin
  assign og_type = 'website'
  assign og_description = meta_desc

  if request.page_type == 'product'
    assign og_type = 'product'
  elsif request.page_type == 'article'
    assign og_type = 'article'
  elsif request.page_type == 'password'
    assign og_url = request.origin
  endif
-%}

<title>
  {{- seo_title -}}
  {%- if current_tags %} — {{ current_tags | join: ', ' }}{% endif -%}
  {%- if current_page != 1 %} — Pág. {{ current_page }}{% endif -%}
</title>

<meta name="description" content="{{ meta_desc | strip_html | escape | truncate: 160 }}">

<link rel="canonical" href="{{ canonical_url }}">

{%- comment -%} Open Graph {%- endcomment -%}
<meta property="og:site_name" content="{{ store_name }}">
<meta property="og:url" content="{{ og_url }}">
<meta property="og:title" content="{{ og_title | escape }}">
<meta property="og:type" content="{{ og_type }}">
<meta property="og:description" content="{{ og_description | strip_html | escape | truncate: 200 }}">
<meta property="og:locale" content="es_MX">

{%- if page_image -%}
  <meta property="og:image" content="https:{{ page_image | image_url: width: 1200 }}">
  <meta property="og:image:secure_url" content="https:{{ page_image | image_url: width: 1200 }}">
  <meta property="og:image:width" content="{{ page_image.width }}">
  <meta property="og:image:height" content="{{ page_image.height }}">
  <meta property="og:image:alt" content="{{ page_image.alt | default: og_title | escape }}">
{%- endif -%}

{%- if request.page_type == 'product' -%}
  <meta property="og:price:amount" content="{{ product.price | money_without_currency | strip_html }}">
  <meta property="og:price:currency" content="{{ cart.currency.iso_code }}">
{%- endif -%}

{%- comment -%} Twitter Card {%- endcomment -%}
{%- if settings.social_twitter_link != blank -%}
  <meta name="twitter:site" content="{{ settings.social_twitter_link | split: 'twitter.com/' | last | prepend: '@' }}">
{%- endif -%}
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ og_title | escape }}">
<meta name="twitter:description" content="{{ og_description | strip_html | escape | truncate: 200 }}">

{%- comment -%} ── STRUCTURED DATA ─────────────────────────────── {%- endcomment -%}

{%- if request.page_type == 'index' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "AutoPartsStore",
  "name": {{ store_name | json }},
  "description": "Refaccionaria digital especializada en refacciones diésel y servicio pesado. Filtros, frenos, lubricantes y más para tractocamiones Kenworth, International y Freightliner.",
  "url": {{ request.origin | json }},
  {% if settings.logo %}"logo": "https:{{ settings.logo | image_url: width: 500 }}",{% endif %}
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Zacatecas",
    "addressRegion": "Zacatecas",
    "addressCountry": "MX"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "22.7709",
    "longitude": "-102.5832"
  },
  "areaServed": {
    "@type": "Country",
    "name": "México"
  },
  "priceRange": "$$",
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
      "opens": "08:00",
      "closes": "18:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": "Saturday",
      "opens": "08:00",
      "closes": "14:00"
    }
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "sales",
    "availableLanguage": "Spanish"
  },
  "knowsAbout": ["Refacciones diésel", "Motores Cummins", "Kenworth", "International", "Freightliner", "Filtros Fleetguard", "Servicio pesado"]
}
</script>
{%- endif -%}

{%- if request.page_type == 'product' and product != blank -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Inicio",
      "item": {{ request.origin | json }}
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": {{ product.type | default: "Refacciones" | json }},
      "item": {{ request.origin | append: '/collections/' | append: product.type | handleize | json }}
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": {{ product.title | json }},
      "item": {{ request.origin | append: product.url | json }}
    }
  ]
}
</script>
{%- endif -%}

{%- if request.page_type == 'collection' and collection != blank -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Inicio",
      "item": {{ request.origin | json }}
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": {{ collection.title | json }},
      "item": {{ request.origin | append: collection.url | json }}
    }
  ]
}
</script>
{%- endif -%}
